    <dashboard name='Story 1' type='storyboard'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98120' id='1' param='vert' removable='false' type-v2='layout-flow' w='99034' x='483' y='940'>
            <zone h='4935' id='3' type-v2='title' w='99034' x='483' y='940' />
            <zone h='11868' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99034' x='483' y='5875' />
            <zone h='81317' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99034' x='483' y='17743'>
              <flipboard active-id='3' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='This dashboard presents an overview of the survey data by displaying key performance indicators such as the total number of respondents, average exercise frequency, average healthy feeling score, and average eating-out frequency. It provides a quick understanding of the overall characteristics of the dataset before exploring detailed analyses.' captured-sheet='KPI&apos;s' id='1' />
                  <story-point caption='This visualization examines breakfast consumption patterns among students. It highlights whether students regularly consume breakfast and helps identify the overall dietary behavior of the surveyed population.' captured-sheet='Breakfast consumption' id='2' />
                  <story-point caption='This chart compares how frequently students eat outside versus prepare meals at home. It provides insights into students&apos; eating habits and indicates their dependence on home-cooked meals or outside food.' captured-sheet='Eating Out vs Cooking Frequency' id='3' />
                  <story-point caption='This visualization compares students&apos; self-reported health status across different genders. It helps identify whether health perceptions differ among demographic groups.' captured-sheet='Health category by gender' id='4' />
                  <story-point caption='This chart investigates the relationship between students&apos; health perception and how rewarding they consider their lives. It highlights the possible connection between physical well-being and life satisfaction.' captured-sheet='People feeling healthy and life rewards' id='5' />
                  <story-point caption='This visualization examines the relationship between exercise frequency and body weight. It helps identify trends between physical activity levels and weight among students.' captured-sheet='Weight vs excercise' id='6' />
                  <story-point caption='This chart summarizes the primary reasons students consume comfort foods, such as stress, boredom, or emotional factors. It provides valuable insights into behavioral eating patterns.' captured-sheet='Comfort food reason' id='7' />
                  <story-point captured-sheet='KPI&apos;s' id='8' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{5D9687B8-7B1E-4AEF-92A8-BFA7B197CCA3}' />
    </dashboard>
