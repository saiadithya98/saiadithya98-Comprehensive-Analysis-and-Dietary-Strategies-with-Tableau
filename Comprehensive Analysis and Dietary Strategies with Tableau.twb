      <aliases enabled='yes' />
      <column caption='Healthy Score' datatype='integer' datatype-customized='true' name='[Calculation_2341977546379266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(([fruit_day] + [veggies_day] + [exercise]) / 3)' />
      </column>
      <column caption='Number of Records' datatype='integer' name='[Calculation_2341977555673091]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Health' datatype='string' name='[Calculation_2341977890299910]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [fruit_day] &gt;= 4&#13;&#10;and [fries] &lt;= 2&#13;&#10;and [veggies_day] &gt;= 4&#13;&#10;and [exercise] &gt;=1&#13;&#10;then &quot;healthy&quot;&#13;&#10;else &quot;Unhealthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Gender1' datatype='string' name='[Calculation_2341977891512327]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Gender]= 2&#13;&#10;then &quot;Male&quot;&#13;&#10;ELSE &quot;Female&quot;&#13;&#10;END' />
      </column>
